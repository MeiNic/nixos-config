# =============================================================================
# NixOS config – Git ignore rules
# =============================================================================

# ── Secrets (NEVER commit) ───────────────────────────────────────────────────
secrets/*
!secrets/*.template
*.passphrase
*.secret
*.key
*.pem
*.p12

# ── hardware-configuration.nix ───────────────────────────────────────────────
# Auto-generated by nixos-generate-config; contains real disk UUIDs.
# Regenerate after hardware changes with: sudo nixos-generate-config
hardware-configuration.nix

# ── NixOS build artefacts ────────────────────────────────────────────────────
result
result-*

# ── Editor / OS noise ────────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/
